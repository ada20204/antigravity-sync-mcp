{
    "name": "antigravity-mcp-sidecar",
    "displayName": "Antigravity MCP Sidecar",
    "description": "All-in-one companion: auto-accept agent prompts + MCP registry routing for Antigravity.",
    "version": "0.1.2",
    "publisher": "antigravity",
    "icon": "icon.png",
    "engines": {
        "vscode": "^1.80.0"
    },
    "activationEvents": [
        "onStartupFinished"
    ],
    "main": "./src/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "antigravityMcpSidecar.toggle",
                "title": "Toggle Antigravity Sidecar Auto-Accept"
            }
        ],
        "configuration": {
            "title": "Antigravity Sidecar",
            "properties": {
                "antigravityMcpSidecar.enabled": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable or disable the auto-accept feature."
                },
                "antigravityMcpSidecar.nativePollInterval": {
                    "type": "number",
                    "default": 500,
                    "description": "Polling interval (ms) for native VS Code commands (Accept, Run)."
                },
                "antigravityMcpSidecar.cdpPollInterval": {
                    "type": "number",
                    "default": 1500,
                    "description": "Polling interval (ms) for CDP webview button clicks (Always Allow)."
                }
            }
        }
    },
    "dependencies": {
        "ws": "^8.19.0"
    },
    "devDependencies": {
        "@types/node": "18.x",
        "@types/vscode": "^1.80.0",
        "typescript": "^5.1.3"
    }
}