{
  "name": "@antigravity-mcp/cli-server",
  "version": "0.1.16",
  "description": "Standalone MCP server driving the Antigravity CLI (agy) in headless print mode",
  "type": "module",
  "main": "build/dist/index.js",
  "bin": {
    "antigravity-cli-mcp": "build/dist/index.js"
  },
  "scripts": {
    "prebuild": "node scripts/generate-version.mjs",
    "build": "tsc",
    "start": "node build/dist/index.js",
    "test": "node --test test/*.test.mjs"
  },
  "keywords": [
    "mcp",
    "antigravity",
    "agy",
    "cli",
    "ai",
    "agent"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "build/dist/",
    "README.md"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "typescript": "^5.9.3"
  }
}
