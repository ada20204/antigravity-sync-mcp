{
    "name": "antigravity-mcp-sidecar",
    "displayName": "Antigravity MCP Sidecar",
    "description": "All-in-one companion: auto-accept agent prompts + MCP registry routing for Antigravity.",
    "version": "0.1.14",
    "publisher": "antigravity",
    "icon": "icon.png",
    "engines": {
        "vscode": "^1.80.0"
    },
    "activationEvents": [
        "onStartupFinished"
    ],
    "extensionKind": [
        "ui",
        "workspace"
    ],
    "main": "./src/extension.js",
    "files": [
        "src/**/*",
        "scripts/**/*",
        "server-runtime/**/*",
        "vendor/ws/**/*",
        "vendor/core/**/*",
        "vendor/sql.js/**/*",
        "package.json",
        "README.md",
        "AI_CONFIG_PROMPT.md",
        "CHANGELOG.md",
        "LICENSE.txt",
        "icon.png"
    ],
    "contributes": {
        "commands": [
            {
                "command": "antigravityMcpSidecar.toggle",
                "title": "Sidecar: Toggle Auto-Accept"
            },
            {
                "command": "antigravityMcpSidecar.showQuota",
                "title": "Sidecar: Show Quota"
            },
            {
                "command": "antigravityMcpSidecar.showQuotaTable",
                "title": "Sidecar: Show Quota Table"
            },
            {
                "command": "antigravityMcpSidecar.refreshQuota",
                "title": "Sidecar: Refresh Quota"
            },
            {
                "command": "antigravityMcpSidecar.launchAntigravity",
                "title": "Sidecar: Launch Antigravity"
            },
            {
                "command": "antigravityMcpSidecar.restartAntigravity",
                "title": "Sidecar: Restart Antigravity"
            },
            {
                "command": "antigravityMcpSidecar.requestHostRestart",
                "title": "Sidecar: Request Host Restart"
            },
            {
                "command": "antigravityMcpSidecar.installBundledServer",
                "title": "Sidecar: Install Bundled MCP Server"
            },
            {
                "command": "antigravityMcpSidecar.showAiConfigPrompt",
                "title": "Sidecar: Show AI Config Prompt"
            },
            {
                "command": "antigravityMcpSidecar.testAccountReadDb",
                "title": "Sidecar: Test Read Current Auth"
            },
            {
                "command": "antigravityMcpSidecar.testAccountSave",
                "title": "Sidecar: Test Save Current Account"
            },
            {
                "command": "antigravityMcpSidecar.testAccountList",
                "title": "Sidecar: Test List Saved Accounts"
            },
            {
                "command": "antigravityMcpSidecar.testAccountClearAndReload",
                "title": "Sidecar: Test Clear Auth and Reload"
            },
            {
                "command": "antigravityMcpSidecar.testAccountRestore",
                "title": "Sidecar: Test Restore Account and Reload"
            },
            {
                "command": "antigravityMcpSidecar.testAccountClearAndRestart",
                "title": "Sidecar: Test Clear Auth and Restart"
            },
            {
                "command": "antigravityMcpSidecar.testAccountRestoreAndRestart",
                "title": "Sidecar: Test Restore Account and Restart"
            },
            {
                "command": "antigravityMcpSidecar.switchAccount",
                "title": "Sidecar: Switch Account"
            },
            {
                "command": "antigravityMcpSidecar.addAnotherAccount",
                "title": "Sidecar: Add Another Account"
            },
            {
                "command": "antigravityMcpSidecar.accountStatus",
                "title": "Sidecar: Account Status"
            },
            {
                "command": "antigravityMcpSidecar.deleteAccount",
                "title": "Sidecar: Delete Saved Account"
            }
        ],
        "menus": {
            "commandPalette": [
                {
                    "command": "antigravityMcpSidecar.testAccountReadDb",
                    "when": "false"
                },
                {
                    "command": "antigravityMcpSidecar.testAccountSave",
                    "when": "false"
                },
                {
                    "command": "antigravityMcpSidecar.testAccountList",
                    "when": "false"
                },
                {
                    "command": "antigravityMcpSidecar.testAccountClearAndReload",
                    "when": "false"
                },
                {
                    "command": "antigravityMcpSidecar.testAccountRestore",
                    "when": "false"
                },
                {
                    "command": "antigravityMcpSidecar.testAccountClearAndRestart",
                    "when": "false"
                },
                {
                    "command": "antigravityMcpSidecar.testAccountRestoreAndRestart",
                    "when": "false"
                }
            ]
        },
        "configuration": {
            "title": "Antigravity Sidecar",
            "properties": {
                "antigravityMcpSidecar.enabled": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable or disable the auto-accept feature."
                },
                "antigravityMcpSidecar.nativePollInterval": {
                    "type": "number",
                    "default": 500,
                    "description": "Polling interval (ms) for native VS Code commands (Accept, Run)."
                },
                "antigravityMcpSidecar.cdpPollInterval": {
                    "type": "number",
                    "default": 1500,
                    "description": "Polling interval (ms) for CDP webview button clicks (Always Allow)."
                },
                "antigravityMcpSidecar.cdpFixedHost": {
                    "type": "string",
                    "default": "",
                    "description": "Optional fixed CDP host override. When set, this host is probed first."
                },
                "antigravityMcpSidecar.cdpFixedPort": {
                    "type": "number",
                    "default": 0,
                    "description": "Optional fixed CDP port override (0 means auto). When set (>0), only this port is probed."
                },
                "antigravityMcpSidecar.cdpPortCandidates": {
                    "type": "string",
                    "default": "9000-9014",
                    "description": "Comma-separated ports/ranges used for CDP probing, e.g. 9000-9014."
                },
                "antigravityMcpSidecar.antigravityExecutablePath": {
                    "type": "string",
                    "default": "",
                    "description": "Optional absolute path to Antigravity executable. Leave empty to auto-detect."
                },
                "antigravityMcpSidecar.antigravityLaunchPort": {
                    "type": "number",
                    "default": 9000,
                    "description": "Preferred launch port when cdpFixedPort is 0. If unavailable, sidecar scans 9000-9014 for the next free port."
                },
                "antigravityMcpSidecar.antigravityLaunchExtraArgs": {
                    "type": "string",
                    "default": "",
                    "description": "Optional extra launch arguments appended when launching Antigravity."
                },
                "antigravityMcpSidecar.bridgeSharedToken": {
                    "type": "string",
                    "default": "",
                    "description": "Optional shared token for sidecar control-plane HMAC auth. Leave empty to auto-manage in ~/.config/antigravity-mcp/bridge.token."
                },
                "antigravityMcpSidecar.bridgeMaxSkewMs": {
                    "type": "number",
                    "default": 120000,
                    "description": "Maximum timestamp skew allowed when verifying signed sidecar control requests."
                },
                "antigravityMcpSidecar.bridgeRequestTtlMs": {
                    "type": "number",
                    "default": 300000,
                    "description": "Maximum age for pending sidecar control requests before auto-reject."
                },
                "antigravityMcpSidecar.bridgeHostEndpoint": {
                    "type": "string",
                    "default": "",
                    "description": "Host bridge endpoint for remote sidecar to connect to (e.g. 127.0.0.1:18900). Leave empty to use default. Configure when using SSH port forwarding to reach the host bridge."
                },
                "antigravityMcpSidecar.quotaWarnThresholdPercent": {
                    "type": "number",
                    "default": 15,
                    "description": "Show warning style/alert when tracked quota falls below this percent."
                },
                "antigravityMcpSidecar.quotaCriticalThresholdPercent": {
                    "type": "number",
                    "default": 5,
                    "description": "Show critical style/alert when tracked quota falls below this percent."
                },
                "antigravityMcpSidecar.quotaAlertCooldownMinutes": {
                    "type": "number",
                    "default": 30,
                    "description": "Minimum minutes between repeated low-quota alerts at the same level."
                },
                "antigravityMcpSidecar.quotaStaleMinutes": {
                    "type": "number",
                    "default": 3,
                    "description": "Mark quota snapshot as stale if older than this many minutes."
                }
            }
        }
    },
    "scripts": {
        "build:server": "cd ../server && npm run build",
        "sync-server-runtime": "node scripts/sync-server-runtime.mjs",
        "prepackage": "npm run build:server && npm run sync-server-runtime",
        "package": "vsce package --no-dependencies",
        "verify": "./verify-vsix.sh",
        "build": "echo 'Sidecar is plain JavaScript, no build needed'",
        "clean": "rm -rf server-runtime/dist server-runtime/node_modules vendor/ws vendor/core",
        "test": "node -c src/extension.js && node -c src/structured-log.js && node -c src/bridge-auth.js && echo 'Sidecar syntax check passed'"
    },
    "dependencies": {
        "@antigravity-mcp/core": "*",
        "@modelcontextprotocol/sdk": "^1.27.1",
        "sql.js": "^1.14.1",
        "ws": "^8.19.0"
    },
    "devDependencies": {
        "@types/node": "^25.3.0",
        "@types/vscode": "^1.80.0",
        "@vscode/vsce": "^3.7.1",
        "typescript": "^5.9.3"
    }
}
