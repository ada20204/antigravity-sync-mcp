{
  "name": "@antigravity-mcp/core",
  "version": "0.1.14",
  "description": "Shared types and utilities for Antigravity MCP",
  "type": "module",
  "main": "dist/cjs/index.cjs",
  "types": "dist/esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.cjs",
      "default": "./dist/esm/index.js"
    }
  },
  "scripts": {
    "build": "npm run clean && tsc -p tsconfig.esm.json && tsc -p tsconfig.cjs.json && node scripts/write-cjs-package-json.mjs && node scripts/create-esm-test-compat.mjs",
    "test": "node --test test/**/*.test.mjs",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\""
  },
  "keywords": ["mcp", "antigravity", "types"],
  "license": "MIT",
  "engines": { "node": ">=18.0.0" },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "@types/ws": "^8.5.4",
    "typescript": "^5.9.3"
  }
}
